# compete web - environment configuration
# Copy to `.env.local` for local development. On Vercel, set these in
# Project Settings -> Environment Variables.

# URL of the FastAPI backend. The app calls /api/* and next.config.mjs
# rewrites those requests to this target, keeping the browser same-origin.
# Local default (when unset) is http://127.0.0.1:8000.
API_PROXY_TARGET=https://your-api-host.example.com

# Optional: call the API directly instead of using the same-origin proxy.
# Leave unset to use the /api rewrite above (recommended).
# NEXT_PUBLIC_API_BASE_URL=
