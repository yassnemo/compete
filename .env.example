# ============================================================
# compete — environment configuration
# Copy to `.env` and fill in. Never commit `.env`.
# ============================================================

# --- Paths ---
# Root for generated data (DuckDB file, parquet staging, reports).
COMPETE_DATA_DIR=./data
# DuckDB warehouse file (relative to repo root or absolute).
COMPETE_DUCKDB_PATH=./data/compete.duckdb

# --- LLM provider selection ---
# One of: gemini | groq | ollama | mock
# `mock` requires no key and is used for tests / offline demos.
COMPETE_LLM_PROVIDER=gemini

# Default model per provider (override if you like).
COMPETE_LLM_MODEL=gemini-1.5-flash

# Gemini (https://aistudio.google.com/apikey — free tier)
GOOGLE_API_KEY=

# Groq (https://console.groq.com/keys — free tier)
GROQ_API_KEY=

# Ollama (local; install from https://ollama.com, then `ollama pull llama3.1`)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1

# Max characters of page text sent to the LLM per extraction (cost control).
COMPETE_LLM_MAX_INPUT_CHARS=6000

# Embeddings provider: hashing (default, zero-dependency, fully offline)
#                    | minilm (sentence-transformers, install `uv sync --extra embed`)
#                    | gemini (uses GOOGLE_API_KEY)
COMPETE_EMBED_PROVIDER=hashing
COMPETE_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
COMPETE_EMBED_DIM=256

# Change detection: cosine >= this between old/new content = minor edit, skip LLM.
COMPETE_DIFF_SIMILARITY_THRESHOLD=0.9

# --- Collection ---
# Polite crawling. User-Agent identifies the bot; keep it honest.
COMPETE_USER_AGENT=compete-intel-bot/0.1 (+https://github.com/your/repo)
COMPETE_REQUEST_TIMEOUT=30
COMPETE_THROTTLE_SECONDS=2.0
COMPETE_RESPECT_ROBOTS=true

# --- Alerts (Phase 6, all optional) ---
COMPETE_ALERTS_ENABLED=false
COMPETE_ALERT_MIN_SIGNIFICANCE=4
SLACK_WEBHOOK_URL=
# Email via SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# --- API ---
COMPETE_API_HOST=127.0.0.1
COMPETE_API_PORT=8000
# Comma-separated origins allowed by CORS (the Next.js dev server).
COMPETE_CORS_ORIGINS=http://localhost:3000
